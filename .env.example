# AUTOEDIT canonical deployment overrides
#
# This file is an example only. Do not commit real values. In production, provide
# secrets through the shell, Unraid template, or another secret store. The active
# docker-compose.yml passes runtime variables explicitly to the container.

# Public access: Nginx Proxy Manager terminates TLS for this domain and proxies
# to http://192.168.50.50:8010.
PUBLIC_DOMAIN=ingest.peteflix.uk
ALLOWED_ORIGINS=https://ingest.peteflix.uk,http://192.168.50.50:8010

# Auth/session gate. Replace these with real deployment secrets outside git.
AUTH_ENABLED=true
SESSION_SECRET=<from secret store>
OPERATOR_PASSWORD=<from secret store>
OPERATOR_USERNAME=peter
OPERATOR_DISPLAY_NAME=Peter
SESSION_COOKIE_NAME=autoedit_session
SESSION_COOKIE_SECURE=true
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_SECONDS=300

# Project data root. In the container this is mounted as /data.
DATA_ROOT=/mnt/user/automulticam

# Canonical central MySQL target. Do not use the historical autoedit-mysql
# container for production.
DB_HOST=192.168.50.50
DB_PORT=3306
DB_NAME=autoedit
DB_USER=autoedit
DB_PASSWORD=<from secret store>

# Ollama / AI settings. The current code is Ollama-only; the provider-neutral
# DeepSeek-primary chain in the roadmap is not wired yet. This is the installed local fallback.
OLLAMA_BASE_URL=http://192.168.50.50:11434
LLM_MODEL=hf.co/unsloth/Qwen3.5-9B-GGUF:Q4_K_M
# Keep mock until the opt-in GPU service passes the live gates in docs/DEPLOYMENT.md.
WHISPER_BACKEND=mock
WHISPER_MODEL=large-v3
WHISPERX_BASE_URL=http://127.0.0.1:8011
WHISPERX_TIMEOUT_SECONDS=3600
WHISPER_LANGUAGE=en
WHISPER_BATCH_SIZE=4
WHISPER_COMPUTE_TYPE=float16
WHISPER_ALIGN=true
WHISPER_DIARIZE=false
WHISPER_DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
# HF_TOKEN is intentionally omitted. Provide it only in the private deployment environment.
DIARIZE_BACKEND=mock

# Media defaults. The current code reads UPLOAD_MAX_CHUNK_BYTES, not UPLOAD_CHUNK_MB.
PROXY_ENCODER=h264_vaapi
PROXY_GOP=12
PROXY_HEIGHT=720
PROXY_CRF=20
PROXY_LOW_HEIGHT=360
PROXY_LOW_CRF=26
UPLOAD_MAX_CHUNK_BYTES=67108864
VAD_DEFAULT_HANGOVER_MS=300
# Direct auto-cut baseline: tiny anti-chatter guard; raise only to loosen twitchy edits.
CUT_MIN_SHOT_MS=250
