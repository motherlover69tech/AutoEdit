# AUTOEDIT deployment configuration
PUBLIC_DOMAIN=autoedit.example.com

# Auth/session gate. Use real secret values from deployment secrets, never commit them.
AUTH_ENABLED=true
SESSION_SECRET=change-me
OPERATOR_PASSWORD=change-me
SESSION_COOKIE_NAME=autoedit_session
SESSION_COOKIE_SECURE=true
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_SECONDS=300

# Project data root on Unraid. In containers this should be mounted at /data.
DATA_ROOT=/mnt/user/automulticam

# MySQL 8 connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=autoedit
DB_USER=autoedit
DB_PASSWORD=change-me

# Queue / worker dependencies for later stages
REDIS_URL=redis://redis:6379
LLM_BASE_URL=http://llm:11434
LLM_MODEL=qwen2.5:14b
WHISPER_BACKEND=faster-whisper
WHISPER_MODEL=small.en

# Media defaults
PROXY_ENCODER=libx264
PROXY_GOP=12
PROXY_HEIGHT=720
PROXY_LOW_HEIGHT=360
UPLOAD_CHUNK_MB=8
VAD_DEFAULT_HANGOVER_MS=300
CUT_MIN_SHOT_MS=1200
